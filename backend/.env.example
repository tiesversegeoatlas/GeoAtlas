DATABASE_URL=sqlite:///./geoatlas_local.db
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
GEOATLAS_PUBLIC_BASE_URL=http://127.0.0.1:8000
GEOATLAS_ADMIN_CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
GEOATLAS_FETCH_TIMEOUT_SECONDS=10
GEOATLAS_MAX_FEED_BYTES=5242880
GEOATLAS_USER_AGENT=GeoAtlasDataCollector/1.0
GEOATLAS_INGEST_MAX_NEW_ITEMS=25
GEOATLAS_INGEST_COMMIT_BATCH_SIZE=5
GEOATLAS_INGEST_ITEM_PAUSE_SECONDS=0.05
GEOATLAS_INGEST_WORKER_COUNT=1
GEOATLAS_ARTICLE_ENRICHMENT_ENABLED=true
GEOATLAS_ARTICLE_FETCH_TIMEOUT_SECONDS=4
GEOATLAS_MAX_ARTICLE_BYTES=2097152
GEOATLAS_HEADLESS_SEARCH_ENABLED=true
GEOATLAS_HEADLESS_SEARCH_URL=https://www.bing.com/search
GEOATLAS_HEADLESS_SEARCH_TIMEOUT_SECONDS=12
# Optional; Chrome and Edge are auto-detected on Windows.
GEOATLAS_HEADLESS_BROWSER_EXECUTABLE=
GEOATLAS_URL_SCRAPE_MAX_ARTICLES=10
GEOATLAS_HEALTH_URL_PROBE_ARTICLES=1
GEOATLAS_EXTERNAL_GEOCODING_ENABLED=true
GEOATLAS_GEOCODER_URL=https://nominatim.openstreetmap.org/search
GEOATLAS_GEOCODER_TIMEOUT_SECONDS=5
GEOATLAS_GEOCODER_MIN_INTERVAL_SECONDS=1.0
