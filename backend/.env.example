DATABASE_URL=sqlite:///./geoatlas_local.db
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
GEOATLAS_PUBLIC_BASE_URL=http://127.0.0.1:8000
GEOATLAS_ADMIN_CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
GEOATLAS_FETCH_TIMEOUT_SECONDS=10
GEOATLAS_MAX_FEED_BYTES=5242880
GEOATLAS_USER_AGENT=GeoAtlasDataCollector/1.0
GEOATLAS_INGEST_MAX_NEW_ITEMS=25
GEOATLAS_INGEST_COMMIT_BATCH_SIZE=5
GEOATLAS_INGEST_ITEM_PAUSE_SECONDS=0
GEOATLAS_INGEST_WORKER_COUNT=1
GEOATLAS_ARTICLE_FETCH_WORKERS=4
GEOATLAS_SCHEDULER_ENABLED=true
GEOATLAS_SCHEDULER_POLL_SECONDS=30
GEOATLAS_SCHEDULER_MAX_PENDING_JOBS=2
GEOATLAS_SCHEDULER_SOURCE_SCAN_LIMIT=200
GEOATLAS_SCHEDULER_JOB_TIMEOUT_SECONDS=300
GEOATLAS_ARTICLE_ENRICHMENT_ENABLED=true
GEOATLAS_ARTICLE_FETCH_TIMEOUT_SECONDS=4
GEOATLAS_MAX_ARTICLE_BYTES=2097152
GEOATLAS_HEADLESS_SEARCH_ENABLED=true
GEOATLAS_HEADLESS_SEARCH_URL=https://www.bing.com/search
GEOATLAS_HEADLESS_SEARCH_TIMEOUT_SECONDS=12
GEOATLAS_HEADLESS_SEARCH_MAX_ITEMS_PER_JOB=3
GEOATLAS_SCHEDULED_HEADLESS_SEARCH_MAX_ITEMS=0
# Optional; Chrome and Edge are auto-detected on Windows.
GEOATLAS_HEADLESS_BROWSER_EXECUTABLE=
GEOATLAS_URL_SCRAPE_MAX_ARTICLES=10
GEOATLAS_HEALTH_URL_PROBE_ARTICLES=1
GEOATLAS_EXTERNAL_GEOCODING_ENABLED=true
GEOATLAS_GEOCODER_URL=https://nominatim.openstreetmap.org/search
GEOATLAS_GEOCODER_TIMEOUT_SECONDS=5
GEOATLAS_GEOCODER_MIN_INTERVAL_SECONDS=1.0
GEOATLAS_AI_ENABLED=false
GEOATLAS_AI_PROVIDER=heuristic
GEOATLAS_AI_MODEL=gemini-2.5-flash
GEOATLAS_AI_API_KEY=
# Ollama example:
# GEOATLAS_AI_PROVIDER=ollama
# GEOATLAS_AI_MODEL=llama3.1:8b
# GEOATLAS_AI_BASE_URL=http://127.0.0.1:11434
# Ollama requires no API key.
# OpenAI API example for paid auto-analysis of only newly ingested items:
# GEOATLAS_AI_ENABLED=true
# GEOATLAS_AI_PROVIDER=openai
# GEOATLAS_AI_MODEL=gpt-4.1-mini
# GEOATLAS_AI_API_KEY=sk-...
# GEOATLAS_AI_BASE_URL=https://api.openai.com/v1
# GEOATLAS_AI_WEB_SEARCH_ENABLED=true
# GEOATLAS_AI_WEB_SEARCH_REQUIRED=true
# GEOATLAS_AI_AUTO_ANALYZE=true
# GEOATLAS_AI_SCHEDULER_BATCH_SIZE=1
# Optional provider endpoint. Leave empty for the provider default.
GEOATLAS_AI_BASE_URL=
GEOATLAS_AI_TIMEOUT_SECONDS=30
GEOATLAS_AI_MAX_RETRIES=2
GEOATLAS_AI_MAX_INPUT_CHARS=12000
GEOATLAS_AI_WORKER_COUNT=2
GEOATLAS_AI_JOB_TIMEOUT_SECONDS=120
GEOATLAS_AI_AUTO_ANALYZE=false
GEOATLAS_AI_SCHEDULER_POLL_SECONDS=5
GEOATLAS_AI_SCHEDULER_BATCH_SIZE=20
GEOATLAS_AI_FALLBACK_ON_ERROR=true
GEOATLAS_AI_BACKFILL_WORKER_COUNT=1
GEOATLAS_AI_ADAPTIVE_WORKERS=true
GEOATLAS_AI_WORKER_MAX_CPU_PERCENT=80
GEOATLAS_AI_WORKER_MIN_FREE_MEMORY_GB=2.0
GEOATLAS_AI_AUX_WORKER_MEMORY_STEP_GB=1.5
GEOATLAS_AI_RESOURCE_CHECK_SECONDS=5
GEOATLAS_AI_BACKFILL_JOB_PAUSE_SECONDS=0.25
# For a single local Ollama GPU/CPU worker, use:
# GEOATLAS_AI_WORKER_COUNT=1
# GEOATLAS_AI_JOB_TIMEOUT_SECONDS=180
# GEOATLAS_AI_AUTO_ANALYZE=true
# GEOATLAS_AI_SCHEDULER_BATCH_SIZE=1
# For an adaptive local pool, use three backfill slots. Auxiliary workers
# automatically pause when CPU or available RAM crosses the configured limits.
# GEOATLAS_AI_BACKFILL_WORKER_COUNT=3
